QMAKE_PRL_TARGET = libQt6QmlCompiler.a
QMAKE_PRL_CONFIG = static
QMAKE_PRL_VERSION = 6.11.1
QMAKE_PRL_LIBS = $$[QT_INSTALL_PREFIX]/lib/objects-Release/QmlCompiler_resources_1/.qt/rcc/qrc_builtins_init.cpp.obj $$[QT_INSTALL_PREFIX]/qml/QML/objects-Release/Qml_resources_1/.qt/rcc/qrc_qmake_QML_init.cpp.obj $$[QT_INSTALL_LIBS]/libQt6QmlCompiler.a $$[QT_INSTALL_LIBS]/libQt6Qml.a $$[QT_INSTALL_LIBS]/libQt6Network.a -ldnsapi -liphlpapi -lsecur32 -lwinhttp $$[QT_INSTALL_LIBS]/libQt6QmlToolingSettings.a $$[QT_INSTALL_LIBS]/libQt6Core.a $$[QT_INSTALL_LIBS]/libQt6BundledZLIB.a -lsynchronization -lmpr -luserenv -ladvapi32 -lauthz -lkernel32 -lnetapi32 -lntdll -lole32 -lruntimeobject -lshell32 -luser32 -luuid -lversion -lwinmm -lws2_32 $$[QT_INSTALL_LIBS]/libQt6BundledPcre2.a -lzstd
QMAKE_PRL_LIBS_FOR_CMAKE = $$[QT_INSTALL_PREFIX]/lib/objects-Release/QmlCompiler_resources_1/.qt/rcc/qrc_builtins_init.cpp.obj;$$[QT_INSTALL_PREFIX]/qml/QML/objects-Release/Qml_resources_1/.qt/rcc/qrc_qmake_QML_init.cpp.obj;$$[QT_INSTALL_LIBS]/libQt6QmlCompiler.a;$$[QT_INSTALL_LIBS]/libQt6Qml.a;$$[QT_INSTALL_LIBS]/libQt6Network.a;-ldnsapi;-liphlpapi;-lsecur32;-lwinhttp;$$[QT_INSTALL_LIBS]/libQt6QmlToolingSettings.a;$$[QT_INSTALL_LIBS]/libQt6Core.a;$$[QT_INSTALL_LIBS]/libQt6BundledZLIB.a;-lsynchronization;-lmpr;-luserenv;-ladvapi32;-lauthz;-lkernel32;-lnetapi32;-lntdll;-lole32;-lruntimeobject;-lshell32;-luser32;-luuid;-lversion;-lwinmm;-lws2_32;$$[QT_INSTALL_LIBS]/libQt6BundledPcre2.a;-lzstd
